{
  "title": "Traffic Data Quality",
  "uid": "traffic-quality",
  "tags": ["traffic", "ai4ads", "anomaly"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Flow-Conservation Violations",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "traffic_flow_violations_active",
          "legendFormat": "Active Violations"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Violation Detection Rate (per minute)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(traffic_flow_violations_total[5m]) * 60",
          "legendFormat": "Violations/min"
        }
      ]
    },
    {
      "id": 3,
      "title": "Correction Success Rate",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(traffic_corrections_successful_total[10m]) / rate(traffic_corrections_attempted_total[10m])",
          "legendFormat": "Success Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.80 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "p95 Inference Latency",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(traffic_api_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Flow-Conservation Violations per Junction Category",
      "description": "Visualises the number of violations detected per road-junction category, providing immediate insight into whether the correction model is converging on accurate predictions.",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (junction_type) (traffic_flow_violations_active)",
          "legendFormat": "{{junction_type}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Violation Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(traffic_flow_violations_total[5m])",
          "legendFormat": "Violations/s"
        }
      ]
    },
    {
      "id": 7,
      "title": "Inference Request Throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(traffic_api_requests_total[5m])",
          "legendFormat": "Requests/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Inference Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(traffic_api_request_duration_seconds_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}